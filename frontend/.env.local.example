# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# Firebase (client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PLATFORM_DOMAIN=nexusblog.io
# Root domain for subdomain routing (e.g. football.nexusblog.io → /blog/football)
NEXT_PUBLIC_ROOT_DOMAIN=nexusblog.io

# Platform blog tenant (server-only — no NEXT_PUBLIC_ prefix)
# Set this to the tenant UUID of NexusBlog's own editorial blog in the DB.
# The /blog and /categories marketing pages fetch content from this tenant.
PLATFORM_TENANT_ID=
