# ─────────────────────────────────────────────────────────────────────
# NexusBlog SaaS — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs réelles
# NE JAMAIS COMMITTER .env dans git
# ─────────────────────────────────────────────────────────────────────

# ── APPLICATION ──────────────────────────────────────────────────────
APP_ENV=development                    # development | staging | production
APP_SECRET_KEY=your-secret-key-here    # 64 chars random hex
DEBUG=true

# ── BASE DE DONNÉES — Neon PostgreSQL ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/smartblog?sslmode=require
# Pour Alembic (migrations — driver sync)
DATABASE_SYNC_URL=postgresql://USER:PASSWORD@HOST/smartblog?sslmode=require&channel_binding=require

# ── REDIS ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ELASTICSEARCH ─────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=

# ── FIREBASE ──────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CLOUDINARY ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── STRIPE ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_FEE_PERCENT=5

# ── PAYPAL ────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox                    # sandbox | live

# ── EMAIL — Resend ────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM_NAME=NexusBlog
EMAIL_FROM_ADDRESS=noreply@nexusblog.io

# ── AI — OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_STRONG_MODEL=gpt-4o

# ── AI — DeepL (traduction) ───────────────────────────────────────────
DEEPL_API_KEY=

# ── AI — ElevenLabs (TTS) ─────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── SÉCURITÉ — Scan de liens pub ──────────────────────────────────────
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=

# ── FRONTEND ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── DOMAINE PLATEFORME ────────────────────────────────────────────────
PLATFORM_DOMAIN=nexusblog.io
PLATFORM_API_DOMAIN=api.nexusblog.io
